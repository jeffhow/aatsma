---
// dog-training-classes.astro
import BaseLayout from "../layouts/BaseLayout.astro";

const registrationLink =
  "https://docs.google.com/document/d/1JdsBjQdPSqAgzqrLwaPaKG2dyvewv_a1sDMxIK1Vvp8/edit?usp=sharing";
---

<BaseLayout>
  <article class="pb-24 pt-36 bg-gray-200">
    <!-- content -->
    <div class="container mx-auto px-6 lg:px-8">
      <header class="text-center max-w-3xl mx-auto mb-8">
        <!-- Section intro with heading + subtext -->
        <h2
          class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight mb-6"
        >
          Dog Training Classes
        </h2>
      </header>
      <p>
        Animal Assisted Therapy Services (AATS) MA provides structured,
        high-quality community dog training classes designed to build
        foundational behavior, obedience, and strong human-canine partnerships.
        Their programs include the AKC S.T.A.R. Puppy course, which focuses on
        early socialization, basic obedience, and responsible pet ownership.
        They also offer an Intermediate Obedience class that mixes training
        center lessons with public field trips to teach handlers how to manage
        commands under real-world distractions. Finally, their AKC Canine Good
        Citizen course serves as an advanced obedience pipeline, thoroughly
        preparing dog teams to remain calm, welcoming, and well-behaved in
        diverse community and crowd settings.
      </p>
    </div>
  </article>
</BaseLayout>
