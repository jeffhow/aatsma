---
// Header.astro
// this gets the url for matching the "active" link in the navbar
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // removes the leading "/"
---

<div x-data="headerLogic()">
  <!-- Fixed header / navbar -->
  <header
    @scroll.window="updateScroll()"
    :class="headerClasses()"
    class="fixed top-0 left-0 w-full z-50 transition-transform duration-300 bg-primary-dark"
  >
    <div
      class="max-w-7xl mx-auto px-6 py-5 lg:px-8 flex items-center justify-between"
    >
      <!-- Logo / home link -->
      <a
        href="/" 
      >
        <h1 class=" hover:text-accent transition-colors text-surface flex flex-col items-start font-header leading-none">
          <span class="text-2xl leading-none mb-1">
            <span class="text-nowrap">Animal Assisted</span> 
            <span class="text-nowrap">Therapy Services</span>
          </span>

          <span class="text-center w-full text-xl font-accent italic bold tracking-wide">of Massachusetts</span>
        </h1>
      </a>

      <!-- Desktop navigation menu -->
      <nav class="hidden lg:block ml-10">
        <ul
          class="flex items-center space-x-8 text-[13px] font-bold tracking-widest uppercase text-white/80"
        >
          <li
            class={currentPath === "/services"
              ? "nav-link-item current-menu-item"
              : "nav-link-item"}
          >
            <a href="/services">Services</a>
          </li>
          <li
            class={currentPath === "/about"
              ? "nav-link-item current-menu-item"
              : "nav-link-item"}
          >
            <a href="/about">About</a>
          </li>
          <li
            class={currentPath === "/contact"
              ? "nav-link-item current-menu-item"
              : "nav-link-item"}
          >
            <a href="/contact">Contact</a>
          </li>
        </ul>
      </nav>

      <!-- Right-side header actions -->
      <div class="flex items-center gap-4 flex-1 justify-end">
        <!-- Search form (desktop only) -->
        <form action="/" method="get" class="relative hidden md:block group">
          <input
            type="text"
            name="s"
            placeholder="Search..."
            class="bg-surface/10 border border-surface/50 text-surface text-sm rounded-full py-2 px-5 pl-10 w-40 lg:w-56 focus:w-72 focus:bg-white focus:text-primary-dark focus:outline-none transition-all duration-500 placeholder:text-white/85"
          />

          <!-- Search icon -->
          <svg
            class="w-4 h-4 absolute left-3.5 top-2.5 text-white/85 group-focus-within:text-primary-dark transition-colors"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            viewBox="0 0 24 24"
          >
            <path d="M21 21l-4.35-4.35M19 11a8 8 0 11-16 0 8 8 0 0116 0z"
            ></path>
          </svg>
        </form>

        <!-- CTA button -->
        <a
          href="/courses"
          class="hidden sm:block bg-accent hover:bg-surface text-primary-dark transition-colors text-[11px] font-black uppercase tracking-[0.15em] px-6 py-2.5 rounded-full transition-all active:scale-95 shadow-lg shadow-orange-500/20"
        >
          Enroll Now
        </a>

        <!-- Mobile menu button -->
        <button @click="mobileMenu = true" class="lg:hidden text-white p-2">
          <svg
            class="w-7 h-7"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile menu (teleported to end of body) -->
  <template x-teleport="body">
    <div>
      <!-- Dark overlay -->
      <div
        x-show="mobileMenu"
        x-cloak
        class="fixed inset-0 bg-primary-dark/60 backdrop-blur-sm z-[60] lg:hidden"
        @click="mobileMenu = false"
        x-transition.opacity
      >
      </div>

      <!-- Slide-in drawer -->
      <div
        x-show="mobileMenu"
        x-cloak
        id="mobile-drawer"
        class="fixed inset-y-0 right-0 w-[300px] bg-primary-dark z-[70] shadow-2xl lg:hidden p-8 flex flex-col"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="translate-x-full"
        x-transition:enter-end="translate-x-0"
        x-transition:leave="transition ease-in duration-300"
        x-transition:leave-start="translate-x-0"
        x-transition:leave-end="translate-x-full"
      >
        <!-- Mobile menu header -->
        <button
          class="flex justify-between items-center font-bold mb-10"
          @click="mobileMenu = false"
        >
          <span
            class="text-surface/80 hover:text-surface transition-colors tracking-tighter text-xl uppercase"
            >Menu</span
          >
          <span class="text-surface/80 hover:text-surface transition-colors">
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </span>
        </button>

        <!-- Mobile navigation links -->
        <nav class="flex-1">
          <ul class="flex flex-col space-y-6 text-xl font-bold text-surface">
            <li
              class={currentPath === ""
                ? "nav-link-item current-menu-item"
                : "nav-link-item"}
            >
              <a href="/">Home</a>
            </li>
            <li
              class={currentPath === "/services"
                ? "nav-link-item current-menu-item"
                : "nav-link-item"}
            >
              <a href="/services">Services</a>
            </li>
            <li
              class={currentPath === "/services"
                ? "nav-link-item current-menu-item ms-5"
                : "nav-link-item ms-2"}
            >
              <a href="#">Dog Training Classes</a>
            </li>
            <li
              class={currentPath === "/about"
                ? "nav-link-item current-menu-item"
                : "nav-link-item"}
            >
              <a href="/about">About</a>
            </li>
            <li
              class={currentPath === "/contact"
                ? "nav-link-item current-menu-item"
                : "nav-link-item"}
            >
              <a href="/contact">Contact</a>
            </li>
          </ul>
        </nav>

        <!-- Mobile CTA -->
        <div class="mt-10 pt-6 border-t border-white/10">
          <a
            href="/courses"
            class="block w-full text-center bg-accent hover:bg-accent-hover text-primary-dark font-black py-4 rounded-xl uppercase tracking-widest text-sm"
          >
            Enroll Now
          </a>
        </div>
      </div>
    </div>
  </template>
</div>

<script is:inline>
  function headerLogic() {
    return {
      atTop: true,
      scrollingDown: false,
      mobileMenu: false,
      lastPos: 0,
      updateScroll() {
        // If the mobile menu is open, don't hide the header!
        if (this.mobileMenu) return;

        const currentPos = window.pageYOffset;
        this.atTop = currentPos <= 50;
        this.scrollingDown = currentPos > this.lastPos && currentPos > 50;
        this.lastPos = currentPos;
      },
      init() {
        this.$watch("mobileMenu", (value) => {
          if (value) {
            document.body.style.overflow = "hidden";
          } else {
            document.body.style.overflow = "";
          }
        });
      },
      headerClasses() {
        return {
          "translate-y-0": !this.scrollingDown,
          "-translate-y-full": this.scrollingDown,
          "bg-primary-dark/90 shadow-md": !this.atTop,
          "bg-primary": this.atTop,
        };
      },
    };
  }
</script>

<style>
  /* Animated underline for nav links */
  .nav-link-item {
    position: relative;
    padding: 0.5rem 0;
  }
  .nav-link-item::after {
    content: "";
    position: absolute;
    width: 0;
    height: 2px;
    bottom: 0;
    left: 0;
    background-color: var(--color-accent);
    transition: width 0.3s ease;
  }
  .nav-link-item:hover::after,
  .current-menu-item::after {
    width: 100%;
  }

  /* Slim custom scrollbar for mobile menu */
  :global(#mobile-drawer::-webkit-scrollbar) {
    width: 4px;
  }
  #mobile-drawer::-webkit-scrollbar-thumb {
    background: #334155;
    border-radius: 10px;
  }
</style>
