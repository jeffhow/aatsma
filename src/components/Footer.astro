---
const now = new Date();
import {Image} from 'astro:assets';
import aatsmaLogo from '../assets/aatsma-new-logo.jpg';
---
<!-- Footer section -->
<footer class="bg-ink text-slate-300 relative overflow-hidden" aria-labelledby="footer-heading">
    
    <!-- Screen-reader only heading for accessibility -->
    <h2 id="footer-heading" class="sr-only">Footer</h2>

    <!-- Subtle dotted background overlay -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 20px 20px;"></div>

    <!-- Main footer container -->
    <div class="container mx-auto px-6 lg:px-8 relative z-10 pt-16 pb-8">
        
        <!-- Footer grid layout -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">
            
            <!-- Brand + description + social links -->
            <div class="space-y-6">
                
                <!-- Logo / brand link -->
                <a href="/" class="flex items-end gap-2 text-white group">
                    <div class="bg-white rounded-xl rounded-t-full p-1 pt-2 overflow-hidden">

                        <Image 
                        src={aatsmaLogo}
                        alt="AATSMA Logo"
                        width={180} 
                        height={180}
                        class="">
                    </div>
                    <span class="group-hover:text-accent transition-colors">Animal Assisted Therapy Services of Massachusetts</span>
                </a>
                
                <!-- Short mission statement -->
                <p class="text-sm leading-relaxed text-slate-400">
                    Dedicated to healing hearts and building bridges through the unconditional love of trained therapy&nbsp;dogs.
                </p>

                <!-- Social media icons -->
                <div class="flex space-x-4">
                    
                    <!-- Facebook -->
                    <a href="#" class="text-slate-400 hover:text-white transition-colors">
                        <span class="sr-only">Facebook</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" class="bi bi-facebook" viewBox="0 0 16 16">
  <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951"/>
</svg>
                    </a>

                    <!-- Instagram -->
                    <a href="#" class="text-slate-400 hover:text-white transition-colors">
                        <span class="sr-only">Instagram</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" class="bi bi-instagram" viewBox="0 0 16 16">
  <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334"/>
</svg>
                    </a>
                </div>
            </div>

            <!-- Organization links -->
            <div>
                <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-6">Organization</h3>
                <ul role="list" class="space-y-4">
                    <li><a href="#" class="text-sm hover:text-accent-dark hover:translate-x-1 transition-all inline-block">About Us</a></li>
                    <li><a href="#" class="text-sm hover:text-accent-dark hover:translate-x-1 transition-all inline-block">Our Team</a></li>
                    <li><a href="#" class="text-sm hover:text-accent-dark hover:translate-x-1 transition-all inline-block">Financials & 990s</a></li>
                    <li><a href="#" class="text-sm hover:text-accent-dark hover:translate-x-1 transition-all inline-block">Careers</a></li>
                </ul>
            </div>

            <!-- Get involved links -->
            <div>
                <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-6">Get Involved</h3>
                <ul role="list" class="space-y-4">
                    <li><a href="#" class="text-sm hover:text-accent-dark hover:translate-x-1 transition-all inline-block">Request a K9 Visit</a></li>
                    <li><a href="#" class="text-sm hover:text-accent-dark hover:translate-x-1 transition-all inline-block">Volunteer</a></li>
                    <li><a href="#" class="text-sm hover:text-accent-dark hover:translate-x-1 transition-all inline-block">Partner With Us</a></li>
                    <li><a href="#" class="text-sm hover:text-accent-dark hover:translate-x-1 transition-all inline-block">Donate</a></li>
                </ul>
            </div>

            <!-- Email signup section -->
            <div>
                <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-6">Join the Pack</h3>
                <p class="text-sm text-slate-400 mb-4">
                    Receive heartwarming stories and impact updates. No spam, ever.
                </p>

                <!-- Newsletter form -->
                <form class="flex flex-col gap-3">
                    <label for="email-address" class="sr-only">Email address</label>

                    <!-- Email input -->
                    <input type="email" name="email-address" id="email-address" autocomplete="email" required 
                        class="w-full min-w-0 appearance-none rounded-lg border-0 bg-white/5 px-4 py-3 text-base text-white ring-1 ring-inset ring-white/10 placeholder:text-slate-500 focus:ring-2 focus:ring-inset focus:ring-accent sm:text-sm sm:leading-6 transition-all" 
                        placeholder="Enter your email">

                    <!-- Subscribe button -->
                    <button type="submit" class="flex-none rounded-lg bg-accent hover:bg-accent-dark px-3.5 py-2.5 text-sm font-bold text-ink shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent transition-colors">
                        Subscribe
                    </button>
                </form>
            </div>
        </div>

        <!-- Bottom footer bar -->
        <div class="border-t border-white/10 pt-8 mt-12 md:flex md:items-center md:justify-between">
            
            <!-- Copyright + nonprofit info -->
            <div class="flex flex-col md:flex-row gap-4 md:gap-8 text-xs text-slate-500">
                <p>&copy; {now.getFullYear()} Animal Assisted Therapy Services of Massachusetts. All rights reserved.</p>
                <p>Animal Assisted Therapy Services of Massachusetts is a registered 501(c)(3) non-profit organization.</p>
            </div>

            <!-- Legal links -->
            <div class="mt-4 md:order-1 md:mt-0">
                <div class="flex gap-6 text-xs text-slate-500">
                    <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
                    <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
                    <a href="#" class="hover:text-white transition-colors">Accessibility</a>
                </div>
            </div>
        </div>
        
    </div>
</footer>