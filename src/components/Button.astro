---
/**
 * @component Button
 * @description A highly reusable, accessible button component that supports 
 * multiple visual variants and scales across the application.
 * @prop {string} href - The destination URL. If provided, renders as an anchor tag.
 * @prop {'primary' | 'secondary' | 'outline' | 'white'} [variant='primary'] - The visual style of the button.
 * @prop {string} [class] - Additional CSS classes for custom positioning or tweaks.
 * @example <Button href="/join" variant="primary">Enroll Now</Button>
 */

interface Props {
  href: string;
  variant?: 'primary' | 'accent' | 'secondary' | 'outline' | 'white';
  class?: string;
}

const { 
  href, 
  variant = 'primary', 
  class: className 
} = Astro.props;

/**
 * @section Style Mapping
 * We define the variant styles in an object to keep the HTML clean 
 * and ensure easy maintenance.
 */
const variants = {
  primary: "bg-primary hover:bg-primary-dark text-surface shadow-slate-900/10",
  accent: "bg-accent hover:bg-accent-dark text-primary-dark shadow-orange-500/20",
  secondary: "bg-muted text-white hover:bg-secondary shadow-slate-900/10",
  outline: "border-2 border-accent text-accent hover:bg-accent hover:text-white",
  white: "bg-white border-2 border-white font-bold text-ink hover:bg-transparent hover:text-white"
};

const baseStyles = "px-6 py-2.5 rounded-full font-black uppercase tracking-widest transition-all active:scale-95 shadow-lg text-center";
---

<a 
  href={href} 
  class:list={[
    baseStyles,
    variants[variant],
    className
  ]}
>
  <slot />
</a>