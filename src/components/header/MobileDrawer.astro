---
/**
 * @component MobileDrawer
 * @description The slide-out navigation menu for mobile devices.
 * Teleports to the body to avoid stacking context issues.
 * @example <MobileDrawer />
 * @requires ../Button.astro
 */

import Search from './Search.astro';
import Button from '../Button.astro';

// this gets the url for matching the "active" link in the navbar
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // removes the leading "/"
---

<div
  x-data="{ open: false }"
  x-init="$watch('open', value => document.body.style.overflow = value ? 'hidden' : '')"
  @toggle-drawer.window="open = !open"
  @close-drawer.window="open = false"
>
  <!-- Mobile menu (teleported to end of body) -->
  <template x-teleport="body">
    <div>
      <!-- Dark overlay -->
      <div
        x-show="open"
        x-cloak
        class="fixed inset-0 bg-primary-dark/60 backdrop-blur-sm z-[60] lg:hidden"
        @click="open = false"
        x-transition.opacity
      >
      </div>

      <!-- Slide-in drawer -->
      <div
        x-show="open"
        x-cloak
        id="mobile-drawer"
        class="fixed inset-y-0 right-0 w-[300px] bg-primary-dark z-[70] shadow-2xl lg:hidden p-8 flex flex-col"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="translate-x-full"
        x-transition:enter-end="translate-x-0"
        x-transition:leave="transition ease-in duration-300"
        x-transition:leave-start="translate-x-0"
        x-transition:leave-end="translate-x-full"
      >
        <!-- Mobile menu header -->
        <button
          class="flex justify-between items-center font-bold mb-10"
          @click="open = false"
        >
          <span
            class="text-surface/80 hover:text-surface transition-colors tracking-tighter text-xl uppercase"
            >Menu</span
          >
          <span class="text-surface/80 hover:text-surface transition-colors">
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </span>
        </button>

        <!-- Mobile navigation links -->
        <nav class="flex-1">
          <ul class="flex flex-col space-y-6 text-xl font-bold text-surface">
            <li
              class={currentPath === ""
                ? "nav-link-item current-menu-item"
                : "nav-link-item"}
            >
              <a href="/">Home</a>
            </li>
            <li
              class={currentPath === "/services"
                ? "nav-link-item current-menu-item"
                : "nav-link-item"}
            >
              <a href="services">Services</a>
            </li>
            <li
              class={currentPath === "/services"
                ? "nav-link-item current-menu-item ms-5"
                : "nav-link-item ms-2"}
            >
              <a href="dog-training-classes">Dog Training Classes</a>
            </li>
            <li
              class={currentPath === "/services"
                ? "nav-link-item current-menu-item ms-5"
                : "nav-link-item ms-2"}
            >
              <a href="therapy-dog-training">Therapy Dog Training Classes</a>
            </li>
            <li
              class={currentPath === "/services"
                ? "nav-link-item current-menu-item ms-5"
                : "nav-link-item ms-2"}
            >
              <a href="animal-assisted-therapy-visits">Animal Assisted Therapy Visit</a>
            </li>
            <li
              class={currentPath === "/about"
                ? "nav-link-item current-menu-item"
                : "nav-link-item"}
            >
              <a href="/about">About</a>
            </li>
            <li
              class={currentPath === "/contact"
                ? "nav-link-item current-menu-item"
                : "nav-link-item"}
            >
              <a href="/contact">Contact</a>
            </li>
            <Search id="mobile-search" />
          </ul>
        </nav>
    
        <div class="mt-10 pt-6 border-t border-white/10">
            
            <!-- Mobile CTA -->
            <Button href="/join" variant="accent" class="rounded-xl text-sm py-4 block w-full">Enroll Now</Button>
        </div>
      </div>
    </div>
  </template>
</div>
