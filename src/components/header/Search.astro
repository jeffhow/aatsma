---
/**
 * @component Search
 * @description The search input field. Contains pagefind which includes
 * inline search results
 * @prop {string} [class] - Additional CSS classes for custom positioning or tweaks.
 * @example <Search />
 */

interface Props {
  id: string,
  class?: string;
}
const { class: className, id: id } = Astro.props;
const baseStyles = "relative group"
---

<div 
  x-data="searchComponent()" 
  class:list={[
    baseStyles,
    className
  ]} >
  <input
    type="text"
    id={id}
    placeholder="Search..."
    @input="handleInput"
    class="bg-surface/10 border border-surface/50 text-surface text-sm rounded-full py-2 px-5 pl-10 w-full xl:w-56 focus:bg-white focus:text-primary-dark focus:outline-none transition-all duration-500"
     />

  <svg
    class="w-4 h-4 absolute left-3.5 top-2.5 text-white/85 group-focus-within:text-primary-dark transition-colors"
    fill="none"
    stroke="currentColor"
    stroke-width="3"
    viewBox="0 0 24 24"
  >
    <path d="M21 21l-4.35-4.35M19 11a8 8 0 11-16 0 8 8 0 0116 0z"></path>
  </svg>

  <div
    x-show="searchOpen"
    @click.away="searchOpen = false"
    x-cloak
    class="absolute top-full right-0 mt-2 w-80 bg-white shadow-xl rounded-lg overflow-hidden z-[60] border border-slate-200"
  >
    <template x-for="result in results" :key="result.url">
      <a
        :href="result.url"
        class="block p-4 hover:bg-slate-50 border-b last:border-0"
      >
        <p
          class="text-xs font-bold text-primary-dark uppercase tracking-wider"
          x-text="result.meta.title"
        >
        </p>
        <p class="text-sm text-slate-600 line-clamp-2" x-html="result.excerpt">
        </p>
      </a>
    </template>
    <div x-show="results.length === 0" class="p-4 text-sm text-slate-500">
      No results found...
    </div>
  </div>
</div>

<script is:inline>
  function searchComponent() {
    return {
      searchOpen: false,
      results: [],
      async handleInput(e) {
        const query = e.target.value;

        if (query.length > 2 && window.pagefind) {
          const search = await window.pagefind.search(query);

          // Load data for the first 5 results
          this.results = await Promise.all(
            search.results.slice(0, 5).map((r) => r.data()),
          );

          this.searchOpen = this.results.length > 0;
        } else {
          this.searchOpen = false;
          this.results = [];
        }
      },
    };
  }

  async function loadPagefind() {
    if (typeof window.pagefind === "undefined") {
      try {
        window.pagefind = await import("/pagefind/pagefind.js");
        await window.pagefind.options({
          // Optional: point to the correct path if your site is in a subfolder
          bundlePath: "/pagefind/",
        });
      } catch (e) {
        console.error("Pagefind failed to load. Did you run the indexer?", e);
      }
    }
  }
  // Load it immediately or on first interaction
  loadPagefind();
</script>
