---
/**
 * @component NavLink
 * @description Desktop navigation component
 * @example <NavLink />
 */

// this gets the url for matching the "active" link in the navbar
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // removes the leading "/"
---

<nav class="hidden lg:block min-[1160px]:ms-10 ms-5 me-5">
  <ul
    class="flex items-center min-[1160px]:gap-8 gap-2 text-[13px] font-bold tracking-widest uppercase text-white/80"
  >
    <li
      class={currentPath === "/services"
        ? "nav-link-item current-menu-item"
        : "nav-link-item"}
    >
      <a href="/services">Services</a>
    </li>

    <li
      class="nav-link-item relative group/dropdown"
      x-data="{ open: false }"
      @mouseenter="open = true"
      @mouseleave="open = false"
    >
      <a
        href="/services"
        class="flex items-center gap-1 uppercase transition-colors hover:text-white"
        :class="open ? 'text-white' : ''"
      >
        Services
        <svg
          class="w-4 h-4 transition-transform duration-200"
          :class="open ? 'rotate-180' : ''"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M19 9l-7 7-7-7"></path>
        </svg>
      </a>

      <div
        x-show="open"
        x-cloak
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 translate-y-2"
        x-transition:enter-end="opacity-100 translate-y-0"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100 translate-y-0"
        x-transition:leave-end="opacity-0 translate-y-2"
        class="absolute left-0 mt-2 w-56 bg-primary-dark border border-white/10 rounded-xl shadow-2xl py-3 z-50"
      >
        <a
          href="/services/training"
          class="block px-6 py-2.5 text-white/70 hover:text-accent hover:bg-white/5 transition-all"
          >Dog Training</a
        >
        <a
          href="/services/therapy"
          class="block px-6 py-2.5 text-white/70 hover:text-accent hover:bg-white/5 transition-all"
          >Therapy Visits</a
        >
        <a
          href="/services/consulting"
          class="block px-6 py-2.5 text-white/70 hover:text-accent hover:bg-white/5 transition-all"
          >Consulting</a
        >
      </div>
    </li>

    <li
      class={currentPath === "/about"
        ? "nav-link-item current-menu-item"
        : "nav-link-item"}
    >
      <a href="/about">About</a>
    </li>
    <li
      class={currentPath === "/contact"
        ? "nav-link-item current-menu-item"
        : "nav-link-item"}
    >
      <a href="/contact">Contact</a>
    </li>
  </ul>
</nav>
