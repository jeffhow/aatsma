---
/**
 * @component Service Card
 * @description Image card with CTA Link for the services page.
 * @example <ServiceCard />
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Button from "../Button.astro";

interface Props {
  title: string;
  imageAsset: ImageMetadata;
  alt: string;
  href: string;
  description: string;
}

const { title, imageAsset, alt, href, description } = Astro.props;
---

<aside
  class="flex flex-col group relative h-120 w-full overflow-clip rounded-3xl shadow-2xl shadow-black/80 mb-8"
>
  <div class="absolute w-full h-full bg-white/0 z-2 transition-all group-hover:bg-white/24"></div>
  <Image
    src={imageAsset}
    alt={alt}
    class="absolute top-0 left-0 z-1 h-120 w-full object-cover object-top"
  />
  <div class="z-2 flex flex-col justify-end h-full">
    <div
      class="p-5 bg-linear-to-t from-ink from-75% to-transparent flex flex-col justify-between"
    >
      <div>
        <h3 class="text-primary-dark text-2xl text-white">
          {title}
        </h3>
        <p
          class="text-white text-sm text-ellipsis overflow-hidden line-clamp-5"
        >
          {description}
        </p>
      </div>
      <Button href={href} variant="white" class="mt-3">Learn More</Button>
    </div>
  </div>
</aside>
